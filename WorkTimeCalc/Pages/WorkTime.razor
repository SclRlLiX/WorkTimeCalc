@page "/"

<PageTitle>Arbeitszeit</PageTitle>

<h1 class="fs-1 mb-4 text-center">Arbeitszeit berechnen</h1>

<div class="row">
    <div class="col-lg">
        <div class="mb-3">
            <label for="start" class="form-label">Arbeitsbeginn</label>
            <input type="time" class="form-control form-select-lg secondary-font text-center" id="start" @bind-value="start" @onfocusout="CalcWorkTime">
        </div>
    </div>

    <div class="col-lg">
        <div class="mb-3">
            <label for="pause" class="form-label">Pause (min)</label>
            <select class="form-select form-select-lg secondary-font text-center" @bind="pause" @onfocusout ="CalcWorkTime">
                @for (int i = 0; i < 999; i++)
                {
                    <option value="@i">@i</option>
                }
            </select>
        </div>
    </div>

    <div class="col-lg">
        <div class="mb-3">
            <label for="end" class="form-label">Arbeitsende</label>
            <input type="time" class="form-control form-select-lg secondary-font text-center" id="end" @bind-value="end"  @onfocusout="CalcWorkTime">
        </div>
    </div>
</div>


<p class="fs-1 text-center mt-5"> 
   <b> @workTime.Hours </b> Stunden und <b> @workTime.Minutes </b> Minuten
</p>

@code {
    public DateTime start = new DateTime(DateTime.Now.Year, DateTime.Now.Month, DateTime.Now.Day, 7, 0, 0);
    public Int32 pause = 30; 
    public DateTime end = new DateTime(DateTime.Now.Year, DateTime.Now.Month, DateTime.Now.Day, 16, 0, 0);
    public TimeSpan workTime;

    protected override void OnInitialized()
    {
        CalcWorkTime();
    }

    private void CalcWorkTime()
    {
        workTime = end.Subtract(start);
        workTime = workTime.Subtract(TimeSpan.FromMinutes(pause));

    }
}